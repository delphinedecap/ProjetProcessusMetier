  "variables" : {
    "mission" : {
      "type" : "url",
      "value" : [
        "../{{context.mission_ref.link}}"
      ],
      "exposed" : false
    },
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.mission ){",
        "\treturn {",
        "\t\t//map mission variable to expected task contract input",
        "\t\tmissionInput: {",
        "\t\t\tprojet: $data.mission.projet !== undefined ? $data.mission.projet : null,",
        "\t\t\tlieu: $data.mission.lieu !== undefined ? $data.mission.lieu : null,",
        "\t\t\tdateDebut: $data.mission.dateDebut !== undefined ? $data.mission.dateDebut : null,",
        "\t\t\tdateFin: $data.mission.dateFin !== undefined ? $data.mission.dateFin : null,",
        "\t\t\tcoutCarbone: $data.mission.coutCarbone !== undefined ? $data.mission.coutCarbone : null,",
        "\t\t\tmanager: $data.mission.manager !== undefined ? $data.mission.manager : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    },
    "roleManagerId" : {
      "type" : "expression",
      "value" : [
        "if (!$data.roles) {\r",
        "    return null;\r",
        "}\r",
        "\r",
        "var role = $data.roles.find(function(r) {\r",
        "    return r.name === \"Manager\";\r",
        "});\r",
        "\r",
        "return role ? role.id : null;"
      ],
      "exposed" : false
    },
    "roles" : {
      "type" : "url",
      "value" : [
        "../API/identity/role?p=0&c=100"
      ],
      "exposed" : false
    },
    "users" : {
      "type" : "url",
      "value" : [
        "../API/identity/user?p=0&c=100"
      ],
      "exposed" : false
    },
    "managerOptions" : {
      "type" : "expression",
      "value" : [
        "if (!$data.users || !$data.memberships || !$data.roleManagerId) {\r",
        "    return [];\r",
        "}\r",
        "\r",
        "var managerIds = $data.memberships\r",
        "    .filter(function(m) {\r",
        "        return String(m.role_id) === String($data.roleManagerId);\r",
        "    })\r",
        "    .map(function(m) {\r",
        "        return String(m.user_id);\r",
        "    });\r",
        "\r",
        "return $data.users\r",
        "    .filter(function(user) {\r",
        "        return managerIds.indexOf(String(user.id)) !== -1;\r",
        "    })\r",
        "    .map(function(user) {\r",
        "        return {\r",
        "            label: user.firstname + \" \" + user.lastname + \" (\" + user.userName + \")\",\r",
        "            value: Number(user.id)\r",
        "        };\r",
        "    });"
      ],
      "exposed" : false
    },
    "memberships" : {
      "type" : "url",
      "value" : [
        "../API/identity/userMembership?p=0&c=100"
      ],
      "exposed" : false
    },
    "actors" : {
      "type" : "url",
      "value" : [
        "../API/bpm/actor?p=0&c=100&f=process_id={{task.processId}}"
      ],
      "exposed" : false
    },
    "actorManagerId" : {
      "type" : "expression",
      "value" : [
        "if (!$data.actors) {\r",
        "    return null;\r",
        "}\r",
        "\r",
        "var actor = $data.actors.find(function(a) {\r",
        "    return a.name === \"Manager\";\r",
        "});\r",
        "\r",
        "return actor ? actor.id : null;"
      ],
      "exposed" : false
    },
    "actorMembers" : {
      "type" : "url",
      "value" : [
        "../API/bpm/actorMember?p=0&c=100&f=actor_id={{actorManagerId}}"
      ],
      "exposed" : false
    },
    "actorManagerRoleId" : {
      "type" : "expression",
      "value" : [
        "if (!$data.actorMembers || $data.actorMembers.length === 0) {\r",
        "    return null;\r",
        "}\r",
        "\r",
        "var roleMember = $data.actorMembers.find(function(m) {\r",
        "    return m.role_id && m.role_id !== \"-1\";\r",
        "});\r",
        "\r",
        "return roleMember ? roleMember.role_id : null;"
      ],
      "exposed" : false
    },
    "roleMemberships" : {
      "type" : "url",
      "value" : [
        "../API/identity/userMembership?p=0&c=100&f=role_id={{actorManagerRoleId}}"
      ],
      "exposed" : false
    },
    "optionsManagers" : {
      "type" : "expression",
      "value" : [
        "if (!$data.managerUsers) {\r",
        "    return [];\r",
        "}\r",
        "\r",
        "return $data.managerUsers.map(function(user) {\r",
        "    return {\r",
        "        label: user.firstname + \" \" + user.lastname + \" (\" + user.userName + \")\",\r",
        "        value: Number(user.id)\r",
        "    };\r",
        "});"
      ],
      "exposed" : false
    },
    "managerUsers" : {
      "type" : "url",
      "value" : [
        "../API/identity/user?p=0&c=100&f=role_id={{actorManagerRoleId}}"
      ],
      "exposed" : false
    }
