    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.mission ){",
        "\treturn {",
        "\t\t//map mission variable to expected task contract input",
        "\t\tmissionInput: {",
        "\t\t\tprojet: $data.mission.projet !== undefined ? $data.mission.projet : null,",
        "\t\t\tlieu: $data.mission.lieu !== undefined ? $data.mission.lieu : null,",
        "\t\t\tdateDebut: $data.mission.dateDebut !== undefined ? $data.mission.dateDebut : null,",
        "\t\t\tdateFin: $data.mission.dateFin !== undefined ? $data.mission.dateFin : null,",
        "\t\t\tcoutCarbone: $data.mission.coutCarbone !== undefined ? $data.mission.coutCarbone : null,",
        "\t\t\tdemandeur: $data.mission.demandeur !== undefined ? $data.mission.demandeur : null,",
        "\t\t\tmanager: $data.mission.manager !== undefined ? $data.mission.manager : null,",
        "\t\t\tstatut: $data.mission.statut !== undefined ? $data.mission.statut : null,",
        "\t\t\tdateDemande: $data.mission.dateDemande !== undefined ? $data.mission.dateDemande : null,",
        "\t\t\tdateValidation: $data.mission.dateValidation !== undefined ? $data.mission.dateValidation : null,",
        "\t\t\tbesoinDoubleApprobation: $data.mission.besoinDoubleApprobation !== undefined ? $data.mission.besoinDoubleApprobation : null,",
        "\t\t\tchoixRSE: $data.mission.choixRSE !== undefined ? $data.mission.choixRSE : null,",
        "\t\t\tchoixManager: $data.mission.choixManager !== undefined ? $data.mission.choixManager : null,",
        "\t\t\tdecisionCollegiale: $data.mission.decisionCollegiale !== undefined ? $data.mission.decisionCollegiale : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    },
    "managerNom" : {
      "type" : "expression",
      "value" : [
        "if (!$data.managerUser) {\r",
        "    return \"\";\r",
        "}\r",
        "\r",
        "return ($data.managerUser.firstname || \"\") + \" \" + ($data.managerUser.lastname || \"\");"
      ],
      "exposed" : false
    },
    "managerUser" : {
      "type" : "url",
      "value" : [
        "../API/identity/user/{{mission.manager}}"
      ],
      "exposed" : false
    },
    "statutTexte" : {
      "type" : "expression",
      "value" : [
        "if (!$data.mission || $data.mission.statut === undefined || $data.mission.statut === null) {\r",
        "    return \"\";\r",
        "}\r",
        "\r",
        "switch (Number($data.mission.statut)) {\r",
        "    case -2:\r",
        "        return \"Suspendue\";\r",
        "    case -1:\r",
        "        return \"Refusée\";\r",
        "    case 0:\r",
        "        return \"En attente de validation\";\r",
        "    case 1:\r",
        "        return \"Validée\";\r",
        "    default:\r",
        "        return \"Statut inconnu\";\r",
        "}"
      ],
      "exposed" : false
    }
