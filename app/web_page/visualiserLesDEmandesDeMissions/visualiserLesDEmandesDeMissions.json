    "managerNom" : {
      "type" : "expression",
      "value" : [
        "if (!$data.managerUser) {\r",
        "    return \"\";\r",
        "}\r",
        "\r",
        "return ($data.managerUser.firstname || \"\") + \" \" + ($data.managerUser.lastname || \"\");"
      ],
      "exposed" : false
    },
    "managerUser" : {
      "type" : "url",
      "value" : [
        "../API/identity/user/{{demande_selected.manager}}"
      ],
      "exposed" : false
    },
    "demandes" : {
      "type" : "businessdata",
      "value" : [
        "{\"displayValue\":\"find [com.company.model.Mission]\",\"businessObjectName\":\"Mission\",\"query\":{\"name\":\"find\",\"displayName\":\"find\"},\"id\":\"com.company.model.Mission\",\"filters\":[],\"pagination\":{\"p\":\"0\",\"c\":\"10\"}}"
      ],
      "exposed" : false
    },
    "statutTexte" : {
      "type" : "expression",
      "value" : [
        "if (!$data.demande_selected || $data.demande_selected.statut === undefined) {\r",
        "    return \"\";\r",
        "}\r",
        "\r",
        "switch ($data.demande_selected.statut) {\r",
        "    case -2:\r",
        "        return \"Suspendue\";\r",
        "    case -1:\r",
        "        return \"Refusée\";\r",
        "    case 0:\r",
        "        return \"En attente de validation\";\r",
        "    case 1:\r",
        "        return \"Validée\";\r",
        "    default:\r",
        "        return \"Statut inconnu\";\r",
        "}"
      ],
      "exposed" : false
    },
    "moyenTransportLibelle" : {
      "type" : "expression",
      "value" : [
        "if (!$data.demande_selected || $data.demande_selected.moyenTransport === undefined || $data.demande_selected.moyenTransport === null) {\r",
        "    return \"\";\r",
        "}\r",
        "\r",
        "var moyensTransport = [\r",
        "    { label: \"Avion\", value: 1 },\r",
        "    { label: \"TGV\", value: 2 },\r",
        "    { label: \"Voiture thermique\", value: 4 },\r",
        "    { label: \"Car\", value: 6 },\r",
        "    { label: \"Vélo électrique\", value: 8 },\r",
        "    { label: \"Voiture électrique\", value: 5 },\r",
        "    { label: \"Moto\", value: 13 },\r",
        "    { label: \"RER / Transilien\", value: 14 },\r",
        "    { label: \"Métro\", value: 11 },\r",
        "    { label: \"Bus thermique\", value: 9 },\r",
        "    { label: \"Trottinette électrique\", value: 17 },\r",
        "    { label: \"Vélo\", value: 7 },\r",
        "    { label: \"Marche\", value: 30 }\r",
        "];\r",
        "\r",
        "var moyen = moyensTransport.find(function(m) {\r",
        "    return Number(m.value) === Number($data.demande_selected.moyenTransport);\r",
        "});\r",
        "\r",
        "return moyen ? moyen.label : \"Moyen inconnu\";"
      ],
      "exposed" : false
    }
  },
