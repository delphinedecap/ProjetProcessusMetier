    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.selfQuota ){",
        "\treturn {",
        "\t\t//map selfQuota variable to expected task contract input",
        "\t\tselfQuotaInput: {",
        "\t\t\tagent: $data.selfQuota.agent !== undefined ? $data.selfQuota.agent : null,",
        "\t\t\tmontant: $data.selfQuota.montant !== undefined ? $data.selfQuota.montant : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "selfQuota" : {
      "type" : "url",
      "value" : [
        "../{{context.selfQuota_ref.link}}"
      ],
      "exposed" : false
    },
