    },
    "titreResultatMission" : {
      "type" : "expression",
      "value" : [
        "if (!$data.mission || $data.mission.statut === undefined || $data.mission.statut === null) {\r",
        "    return \"Résultat de votre demande de mission\";\r",
        "}\r",
        "\r",
        "switch (Number($data.mission.statut)) {\r",
        "    case 1:\r",
        "        return \"Votre mission a été validée\";\r",
        "    case -2:\r",
        "        return \"Votre mission a été suspendue\";\r",
        "    case -1:\r",
        "        return \"Votre mission a été refusée\";\r",
        "    case 0:\r",
        "        return \"Votre demande de mission est en attente\";\r",
        "    default:\r",
        "        return \"Résultat de votre demande de mission\";\r",
        "}"
      ],
      "exposed" : false
    },
    "managerNom" : {
      "type" : "expression",
      "value" : [
        "if (!$data.managerUser) {\r",
        "    return \"\";\r",
        "}\r",
        "\r",
        "return ($data.managerUser.firstname || \"\") + \" \" + ($data.managerUser.lastname || \"\");"
      ],
      "exposed" : false
    },
    "managerUser" : {
      "type" : "url",
      "value" : [
        "../API/identity/user/{{mission.manager}}"
      ],
      "exposed" : false
    },
    "statutTexte" : {
      "type" : "expression",
      "value" : [
        "if (!$data.mission || $data.mission.statut === undefined || $data.mission.statut === null) {\r",
        "    return \"\";\r",
        "}\r",
        "\r",
        "switch (Number($data.mission.statut)) {\r",
        "    case -2:\r",
        "        return \"Suspendue\";\r",
        "    case -1:\r",
        "        return \"Refusée\";\r",
        "    case 0:\r",
        "        return \"En attente de validation\";\r",
        "    case 1:\r",
        "        return \"Validée\";\r",
        "    default:\r",
        "        return \"Statut inconnu\";\r",
        "}"
      ],
      "exposed" : false
    }
