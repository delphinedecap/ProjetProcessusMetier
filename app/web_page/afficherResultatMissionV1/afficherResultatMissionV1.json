    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if ($data.mission) {\r",
        "    return {\r",
        "        missionInput: {\r",
        "            projet: $data.mission.projet !== undefined ? $data.mission.projet : null,\r",
        "            lieu: $data.mission.lieu !== undefined ? $data.mission.lieu : null,\r",
        "            dateDebut: $data.mission.dateDebut !== undefined ? $data.mission.dateDebut : null,\r",
        "            dateFin: $data.mission.dateFin !== undefined ? $data.mission.dateFin : null,\r",
        "            coutCarbone: $data.mission.coutCarbone !== undefined ? $data.mission.coutCarbone : null,\r",
        "            demandeur: $data.mission.demandeur !== undefined ? $data.mission.demandeur : null,\r",
        "            manager: $data.mission.manager !== undefined ? $data.mission.manager : null,\r",
        "            statut: $data.mission.statut !== undefined ? $data.mission.statut : null,\r",
        "            dateDemande: $data.mission.dateDemande !== undefined ? $data.mission.dateDemande : null,\r",
        "            dateValidation: $data.mission.dateValidation !== undefined ? $data.mission.dateValidation : null\r",
        "        }\r",
        "    };\r",
        "}\r",
        "\r",
        "return {};"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
