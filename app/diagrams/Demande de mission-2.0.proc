        <defaultValue xmi:type="expression:Expression" xmi:id="_HwJE7WY4EfG2XcJ39Idavg" name="init_quotaCarbonne()" content="import org.bonitasoft.engine.identity.User&#xD;&#xA;import org.bonitasoft.engine.identity.UserNotFoundException&#xD;&#xA;&#xD;&#xA;User user = null&#xD;&#xA;&#xD;&#xA;try {&#xD;&#xA;&#x9;def processInstance = apiAccessor.getProcessAPI().getProcessInstance(processInstanceId)&#xD;&#xA;&#x9;user = apiAccessor.getIdentityAPI().getUser(processInstance.getStartedBy())&#xD;&#xA;} catch (UserNotFoundException e) {&#xD;&#xA;&#x9;throw new IllegalStateException(&quot;Impossible de trouver l'utilisateur ayant démarré le processus&quot;, e)&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (user == null) {&#xD;&#xA;&#x9;throw new IllegalStateException(&quot;Utilisateur initiateur introuvable&quot;)&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;def quotas = quotaCarboneDAO.findByAgent(user.id, 0, 1)&#xD;&#xA;&#xD;&#xA;if (quotas == null || quotas.isEmpty()) {&#xD;&#xA;&#x9;return quotaCarboneDAO.newInstance(user.id, 1000000.0)&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;return quotas.get(0)" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.company.model.QuotaCarbone">
